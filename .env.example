# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=filevault
POSTGRES_USER=filevault
POSTGRES_PASSWORD=changeme

# ── API ───────────────────────────────────────────────────────────────────────
# asyncpg DSN — uses the postgres service name as the host inside Docker
DATABASE_URL=postgresql+asyncpg://filevault:changeme@postgres:5432/filevault

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000

ENVIRONMENT=development

# JWT signing key — MUST be 32+ random bytes in production (256-bit minimum).
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-secret-key-before-production

# Optional: separate database for pytest (defaults to filevault_test)
# TEST_DATABASE_URL=postgresql+asyncpg://filevault:changeme@postgres:5432/filevault_test

# ── MinIO / S3 ────────────────────────────────────────────────────────────────
# In production, replace with AWS S3 values and remove S3_ENDPOINT_URL
S3_ENDPOINT_URL=http://minio:9000
S3_BUCKET=file-vault
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin123

# ── Frontend ──────────────────────────────────────────────────────────────────
# Must be reachable from the *browser*, not from inside Docker
NEXT_PUBLIC_API_URL=http://localhost:8000
# Server-side RSC fetches from the web container (docker-compose sets this automatically)
API_INTERNAL_URL=http://api:8000
