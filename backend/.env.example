# Used when running the API outside Docker (e.g. uv run uvicorn ... locally)
# Inside Docker, these are provided by docker-compose.yml via the root .env

DATABASE_URL=postgresql+asyncpg://filevault:changeme@localhost:5432/filevault
CORS_ORIGINS=http://localhost:3000
ENVIRONMENT=development
# JWT signing key — MUST be 32+ random bytes in production (256-bit minimum).
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-secret-key-before-production
# Optional: separate database for pytest (defaults to filevault_test)
# TEST_DATABASE_URL=postgresql+asyncpg://filevault:changeme@localhost:5432/filevault_test
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET=file-vault
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin123
